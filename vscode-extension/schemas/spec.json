{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://crewhaus.io/schemas/spec.json",
  "title": "CrewHaus Spec",
  "description": "v0 spec discriminated on `target`. Mirrors @crewhaus/spec.",
  "oneOf": [
    {
      "type": "object",
      "required": ["name", "target", "agent"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "cli" },
        "agent": {
          "type": "object",
          "required": ["model", "instructions"],
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "instructions": { "type": "string", "minLength": 1 }
          }
        },
        "tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    {
      "type": "object",
      "required": ["name", "target", "model", "steps"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "workflow" },
        "model": { "type": "string", "minLength": 1 },
        "steps": { "type": "array", "minItems": 1 }
      }
    },
    {
      "type": "object",
      "required": ["name", "target", "agent", "channels", "routing"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "channel" },
        "agent": { "type": "object" },
        "channels": { "type": "object" },
        "routing": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "graph" } }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "managed" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "pipeline" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "crew" } }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "research" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "batch" } }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "voice" } }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "browser" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "eval" } }
    }
  ]
}
