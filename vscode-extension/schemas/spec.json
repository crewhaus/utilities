{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://crewhaus.ai/schemas/spec.json",
  "title": "CrewHaus Spec",
  "description": "v0 spec discriminated on `target`. Mirrors @crewhaus/spec.",
  "oneOf": [
    {
      "type": "object",
      "required": ["name", "target", "agent"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "cli" },
        "agent": {
          "type": "object",
          "required": ["model", "instructions"],
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "instructions": { "type": "string", "minLength": 1 }
          }
        },
        "tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    {
      "type": "object",
      "required": ["name", "target", "model", "steps"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "workflow" },
        "model": { "type": "string", "minLength": 1 },
        "steps": { "type": "array", "minItems": 1 }
      }
    },
    {
      "type": "object",
      "required": ["name", "target", "agent", "channels", "routing"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "channel" },
        "agent": { "type": "object" },
        "channels": { "type": "object" },
        "routing": { "type": "object" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "graph" } }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "managed" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "pipeline" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "crew" } }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "research" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "batch" } }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "target": { "const": "voice" } }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "browser" }
      }
    },
    {
      "type": "object",
      "required": ["name", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "const": "eval" },
        "agent": { "type": "object" },
        "dataset": { "type": "object" },
        "graders": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "kind"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "kind": {
                "enum": [
                  "exact-match",
                  "contains",
                  "numeric-tolerance",
                  "json-schema",
                  "llm-judge",
                  "custom-script"
                ]
              },
              "expected": {},
              "pattern": { "type": "string", "minLength": 1 },
              "regex": { "type": "boolean" },
              "caseSensitive": { "type": "boolean" },
              "tolerance": { "type": "number", "minimum": 0 },
              "mode": { "enum": ["absolute", "relative"] },
              "schema": { "type": "object" },
              "rubric": { "type": "string", "minLength": 1 },
              "model": { "type": "string", "minLength": 1 },
              "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
              "script": { "type": "string", "minLength": 1 },
              "timeoutMs": { "type": "integer", "exclusiveMinimum": 0 },
              "weight": { "type": "number", "exclusiveMinimum": 0 }
            }
          }
        }
      }
    }
  ]
}
