{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "@crewhaus/errors": ["../factory/packages/errors/src/index.ts"],
      "@crewhaus/ir": ["../factory/packages/ir/src/index.ts"],
      "@crewhaus/spec": ["../factory/packages/spec/src/index.ts"],
      "@crewhaus/trace-event-bus": ["../factory/packages/trace-event-bus/src/index.ts"]
    }
  }
}
