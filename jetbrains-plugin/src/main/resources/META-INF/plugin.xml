<idea-plugin>
  <id>io.crewhaus.jetbrains-plugin</id>
  <name>CrewHaus</name>
  <vendor email="maintainers@crewhaus.io" url="https://github.com/crewhaus/crewhaus-factory">CrewHaus</vendor>

  <description><![CDATA[
    <h2>CrewHaus for IntelliJ / WebStorm / PyCharm</h2>
    <p>
      Spec authoring + run-from-editor for the CrewHaus meta-harness compiler.
      Mirrors the VS Code extension's surface (autocomplete + lint + Run Spec)
      and adds JetBrains-native features:
    </p>
    <ul>
      <li>Schema-driven autocomplete on <code>crewhaus.yaml</code> via the
          built-in YAML plugin's JSON Schema integration.</li>
      <li>Run / debug configurations: <em>Run Spec</em>, <em>Run Eval</em>,
          <em>Run Canary</em>.</li>
      <li>Spec-registry tool window (Database tools integration with the
          §28 Postgres adapter).</li>
    </ul>
  ]]></description>

  <change-notes><![CDATA[
    <h3>0.0.0</h3>
    <ul>
      <li>Initial scaffold (Section 35b).</li>
    </ul>
  ]]></change-notes>

  <depends>com.intellij.modules.platform</depends>
  <depends>org.jetbrains.plugins.yaml</depends>

  <extensions defaultExtensionNs="com.intellij">
    <!-- Schema provider so YAML plugin's autocomplete + lint fires on
         crewhaus.yaml files. Path resolution is handled by the
         CrewhausSpecSchemaProvider Kotlin class below. -->
    <jsonSchema.providerFactory implementation="io.crewhaus.plugin.schema.CrewhausSpecSchemaProviderFactory"/>

    <!-- Run configuration types. -->
    <configurationType implementation="io.crewhaus.plugin.run.RunSpecConfigurationType"/>
    <configurationType implementation="io.crewhaus.plugin.run.RunEvalConfigurationType"/>
    <configurationType implementation="io.crewhaus.plugin.run.RunCanaryConfigurationType"/>

    <!-- Spec-registry tool window. -->
    <toolWindow id="CrewHaus Spec Registry" anchor="bottom"
                factoryClass="io.crewhaus.plugin.toolwindow.SpecRegistryToolWindowFactory"
                icon="/icons/crewhaus-tool-window.svg"/>
  </extensions>

  <actions>
    <action id="crewhaus.runSpec" class="io.crewhaus.plugin.actions.RunSpecAction"
            text="Run Spec"
            description="Run the active CrewHaus spec via crewhaus run">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
    <action id="crewhaus.openTrace" class="io.crewhaus.plugin.actions.OpenTraceAction"
            text="Open Trace Viewer"
            description="Open the Studio v1 trace viewer for the active run">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
